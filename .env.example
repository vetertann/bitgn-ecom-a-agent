# BitGN harness
BENCHMARK_HOST=https://api.bitgn.com
BENCHMARK_ID=bitgn/ecom1-dev
BITGN_API_KEY=

# Default model + provider used as the prompt-iteration model
MODEL_ID=Qwen/Qwen3.5-397B-A17B-fast
MODEL_PROVIDER=nebius

# Tool-calling mode: "native" or "prompt_json" (prompt_json is the agnostic default)
# MODEL_TOOL_MODE=prompt_json

# Hot-loaded markdown skills (file names under Skills/)
# SKILL=ecom.md
# PRESUBMIT_SKILL=presubmit.md

# Providers — only set the ones you use
NEBIUS_BASE_URL=https://api.tokenfactory.us-central1.nebius.com/v1/
NEBIUS_API_KEY=

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=

CEREBRAS_BASE_URL=https://api.cerebras.ai
CEREBRAS_API_KEY=

# Optional runtime tuning
# MODEL_TIMEOUT_SECONDS=120
# MODEL_MAX_OUTPUT_TOKENS=4096
# MODEL_MAX_ATTEMPTS=4
# MODEL_SCHEMA_MAX_RETRIES=3
# DEEPSEEK_THINKING=enabled
